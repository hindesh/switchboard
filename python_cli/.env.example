# Anthropic API
ANTHROPIC_API_KEY=your_key_here

# Redis (leave blank to use in-memory fallback)
REDIS_URL=redis://localhost:6379

# Database (leave blank to use SQLite)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/switchboard
# DATABASE_URL=sqlite+aiosqlite:///./switchboard.db

# App settings
LOG_LEVEL=INFO
ENV=development

# Routing thresholds
VENDOR_CONFIDENCE_THRESHOLD=0.6
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
VENDOR_BOT_MODEL=claude-haiku-4-5-20251001
INTERNAL_AGENT_MODEL=claude-sonnet-4-6
